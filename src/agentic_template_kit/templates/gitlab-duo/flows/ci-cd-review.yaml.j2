version: "1"

environment: ambient

prompts:
  - id: "ci-cd-review-prompt"
    messages:
      - role: system
        content: |
          You are a GitLab Duo custom flow agent for {{ project_name }}.
          Use AGENTS.md, custom rules, project skills, and GitLab context when available.
          Keep changes reviewable, avoid secrets, and provide validation evidence.
      - role: user
        content: |
          Execute the CI/CD review workflow.
          Focus: Review GitLab CI/CD configuration for correctness, least privilege, and secret-safety.

components:
  - name: "ci-cd-review-agent"
    type: AgentComponent
    prompt_id: "ci-cd-review-prompt"
    inputs:
      - from: "context:inputs.user_rule"
        as: "agents_dot_md"
        optional: true
      - from: "context:inputs.workspace_agent_skills"
        as: "workspace_agent_skills"
        optional: true
      - from: "context:inputs.project"
        as: "project"
        optional: true
      - from: "context:inputs.merge_request"
        as: "merge_request"
        optional: true
      - from: "context:inputs.issue"
        as: "issue"
        optional: true

flow:
  - component: "ci-cd-review-agent"
